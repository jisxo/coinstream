# --- Broker / Topics ---
KAFKA_BROKERS=redpanda:9092
TOPIC_TRADES=trades_raw
TOPIC_DLQ=trades_dlq

# --- Binance WebSocket ---
# Use lowercase symbols like btcusdt, ethusdt, solusdt ...
SYMBOLS=btcusdt,ethusdt,solusdt
# Spot combined-stream endpoint. For futures, switch base to: wss://fstream.binance.com/stream?streams=
BINANCE_WS_BASE=wss://stream.binance.com:9443/stream?streams=

# --- Processing semantics ---
WINDOW_MS=60000
ALLOWED_LATENESS_MS=10000
DEDUP_TTL_SECONDS=600
DEDUP_MAXSIZE=500000

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=crypto

# --- MinIO (S3) ---
# In docker compose, MinIO runs in-container on http://minio:9000 (host port mapped to 9002)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=crypto
S3_PREFIX=ohlc_1m

# --- Metrics ports (host-mapped in compose) ---
INGEST_METRICS_PORT=8000
PROCESSOR_METRICS_PORT=8000

# --- checkpoint --- 
CHECKPOINT_INTERVAL_MS=15000
CHECKPOINT_STORE=redis
CHECKPOINT_REDIS_URL=redis://redis:6379/0
CHECKPOINT_REDIS_KEY=coinstream:checkpoint
CHECKPOINT_FILE_PATH=/tmp/coinstream_checkpoint.json

# --- Redash (replace secrets; don't commit production secrets) ---
REDASH_DB_NAME=redash
REDASH_DB_USER=redash
REDASH_DB_PASSWORD=redash
REDASH_DATABASE_URL=postgresql://redash:${REDASH_DB_PASSWORD}@redash-postgres:5432/${REDASH_DB_NAME}
REDASH_REDIS_URL=redis://redash-redis:6379/0
REDASH_COOKIE_SECRET=replace-with-secure-cookie
REDASH_SECRET_KEY=replace-with-secure-secret
REDASH_LOG_LEVEL=INFO
REDASH_GUNICORN_TIMEOUT=120

# --- Prometheus email alerting (optional) ---
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_FROM=
SMTP_AUTH_USERNAME=
SMTP_AUTH_PASSWORD=
ALERT_EMAIL_TO=
SMTP_REQUIRE_TLS=true
